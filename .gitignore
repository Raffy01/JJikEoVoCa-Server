# ---------------------------------------------------
# 1. 보안 및 인증 키 (Security & Credentials)
# ---------------------------------------------------
# GCP 서비스 계정 마스터 키 (유출 시 클라우드 탈취 위험)
my-service-account-key.json

# 환경 변수 파일 (API 키 보관용)
.env

# TLS/SSL 인증서 및 개인키
res/cert/*.key
res/cert/*.crt
res/cert/*.pem

# 테스트용 인증서
tests/fixtures/cert/server.crt

# ---------------------------------------------------
# 2. 데이터베이스 및 저장소 (Databases & Vector Stores)
# ---------------------------------------------------
# SQLite 데이터베이스 (개인 정보 및 세션 로그 포함)
res/database/*.db
res/database/*.sqlite3

# ChromaDB 벡터 저장소 (용량 문제 및 로컬 데이터)
res/database/chroma_db_data/

# ---------------------------------------------------
# 3. 로그 및 임시 업로드 파일 (Logs & Uploads)
# ---------------------------------------------------
# 서버 구동 로그
res/logs/
*.log

# ---------------------------------------------------
# 4. 파이썬 및 가상환경 (Python & Environments)
# ---------------------------------------------------
# 바이트코드 캐시
__pycache__/
*.py[cod]
*$py.class

# 가상환경 폴더 (용량 낭비 방지)
venv/
env/
.venv/

# ---------------------------------------------------
# 5. OS 및 에디터 설정 (OS & IDEs)
# ---------------------------------------------------
# Windows/Mac 시스템 파일
Thumbs.db
.DS_Store

# PyCharm 에디터 설정 파일
.idea/